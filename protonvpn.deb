    }

    body {
        background-color: #f7f5ff;
        text-align: center
    }

    .container {
        margin-left: auto;
        margin-right: auto;
        padding-left: 2rem;
        padding-right: 2rem;
        margin: auto
    }

    @media(min-width:48em) {
        .container {
            padding-left: 3rem;
            padding-right: 3rem
        }
    }

    @media(min-width:80em) {
        .container {
            padding-left: 6rem;
            padding-right: 6rem
        }
    }

    h1 {
        font-weight: 400;
        font-size: 56px;
        line-height: 56px;
        text-align: center;
        color: #372580;
        flex: none;
        order: 0;
        flex-grow: 0;
        margin: auto
    }

    p {
        font-weight: 400;
        font-size: 22px;
        line-height: 28px;
        text-align: center;
        color: #372580;
        flex: none;
        order: 1;
        flex-grow: 0;
        margin-top: 1rem;
        margin-bottom: 0
    }

    a.button {
        padding-top: .875rem;
        padding-bottom: .875rem;
        padding-left: 2rem;
        padding-right: 2rem;
        font-size: 1.375rem;
        line-height: 1.27;
        border-width: 2px;
        --tw-border-opacity: 1;
        border-color: rgb(109 74 255/var(--tw-border-opacity));
        --tw-bg-opacity: 1;
        background-color: rgb(109 74 255/var(--tw-bg-opacity));
        --tw-text-opacity: 1;
        color: rgb(255 255 255/var(--tw-text-opacity));
        border-radius: 9999px;
        display: inline-block;
        text-decoration: inherit;
        font-weight: 500
    }

    @media(min-width:64em) {
        a.button {
            margin-left: 0;
            margin-right: 0
        }
    }

    .main {
        padding-top: 2rem;
        padding-bottom: 2rem;
        row-gap: 1rem;
        align-items: center;
        flex-direction: column;
        display: flex;
        margin: auto
    }

    @media(min-width:64em) {
        .main {
            padding-top: 5rem;
            padding-bottom: 5rem
        }
    }

    @media(min-width:48em) {
        .main {
            padding-top: 3rem;
            padding-bottom: 3rem
        }
    }

    @media(min-width:48em) {
        .main {
            row-gap: 2.5rem
        }
    }

    img {
        height: 12rem;
        margin-top: 1.5rem;
        margin-left: auto;
        margin-right: auto;
        max-width: 100%;
        height: auto;
        display: block
    }

    @media(min-width:64em) {
        img {
            margin-top: 0;
            margin-left: 0;
            margin-right: 0;
            height: auto
        }
    }

    @media(min-width:64em) {
        .content {
            width: 838px
        }
    }

    .content a {
        color: #6d4aff;
        text-decoration: inherit;
        font-weight: 700
    }

    svg {
        max-width: 100%
    }
</style>
